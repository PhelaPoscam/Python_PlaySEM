[flake8]
max-line-length = 88
extend-ignore = E203, W503, F541, E402, W391
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    tests/*: F401, F841, F811, E501
    tests/*/*: F401, F841, F811, E501
    tests/*/*/*: F401, F841, F811, E501
    playsem/__init__.py: F401
    examples/scenes/thunderstorm.py: E741
