# PlaySEM Local Environment Configuration Example
# Copy this file to '.env' in the project root and adjust the values as needed.

# FastAPI/Web Server Port (Default: 8090)
PLAYSEM_SERVER_PORT=8090

# Embedded MQTT Broker Port (Default: 1883)
PLAYSEM_MQTT_PORT=1883

# Embedded CoAP Server Port (Default: 5683)
PLAYSEM_COAP_PORT=5683

# Embedded UPnP HTTP Server Port (Default: 8008)
PLAYSEM_UPNP_HTTP_PORT=8008

# Force exit server on shutdown (0 or 1, Default: 0)
PLAYSEM_FORCE_EXIT=0
